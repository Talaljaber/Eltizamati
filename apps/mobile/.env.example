# Supabase — personal mode only (demo mode needs none of this).
# EXPO_PUBLIC_* vars are inlined into the client bundle by Metro at build
# time — never put the service-role key here or in any EXPO_PUBLIC_ var.
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Sentry (ADR-0015) — release builds only (preview/production EAS profiles);
# leaving this empty keeps Sentry fully inert, including in those profiles.
EXPO_PUBLIC_SENTRY_DSN=
