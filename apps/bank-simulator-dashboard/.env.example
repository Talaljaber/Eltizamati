# Eltizamati Bank Simulator — local environment template.
#
# Copy to `.env.local` and fill in LOCAL Supabase / SMTP values only.
# NEVER commit `.env` or `.env.local`. NEVER put a secret value in a
# NEXT_PUBLIC_-prefixed variable — this app has no browser-visible secrets.

# ── Demo gate ────────────────────────────────────────────────────────────
DEMO_DASHBOARD_ENABLED=true
DEMO_DASHBOARD_ALLOW_REMOTE=false

# ── Test-data allowlist (comma-separated) — required, or the dashboard
#    refuses to load any client-level information ────────────────────────
DEMO_ALLOWED_USER_IDS=
DEMO_ALLOWED_EMAILS=

# ── Supabase (server-only; SUPABASE_SECRET_KEY must never reach the
#    browser bundle) ───────────────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SECRET_KEY=

# ── Email (Gmail SMTP). Recipients are gated by the same test-data
#    allowlist above — only an email already on file for an allowlisted
#    profile can ever receive mail, no separate list to configure ─────────
EMAIL_SENDING_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_SENDER_NAME=Eltizamati Demo
SMTP_SENDER_EMAIL=
