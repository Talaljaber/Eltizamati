# Eltizamati Bank Simulator — local environment template.
#
# Copy to `.env.local` and fill in LOCAL Supabase / SMTP values only.
# NEVER commit `.env` or `.env.local`. NEVER put a secret value in a
# NEXT_PUBLIC_-prefixed variable — this app has no browser-visible secrets.

# ── Demo gate ────────────────────────────────────────────────────────────
DEMO_DASHBOARD_ENABLED=true
DEMO_DASHBOARD_ALLOW_REMOTE=false

# ── (Removed) Test-data allowlist ─────────────────────────────────────────
#    DEMO_ALLOWED_USER_IDS / DEMO_ALLOWED_EMAILS are no longer used. The
#    dashboard reads across all personal accounts, and outgoing email is gated
#    per recipient by their own consent (accepted with the Terms & Conditions
#    in the mobile app) rather than by a static allowlist.

# ── Supabase (server-only; SUPABASE_SECRET_KEY must never reach the
#    browser bundle) ───────────────────────────────────────────────────────
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SECRET_KEY=

# ── Field decryption (server-only) ────────────────────────────────────────
#    Shared token the dashboard presents to the `operator-decrypt` Edge Function
#    (which holds the KEK) to decrypt the client-encrypted PII columns
#    (full_name, phone_number, primary_bank, obligation nickname/notes) for
#    display. This is NOT the KEK — the master key never lives in this app.
#    Set the SAME value as the Edge Function's OPERATOR_DECRYPT_TOKEN secret
#    (generate with: openssl rand -hex 32). Leave unset to show those columns as
#    raw ciphertext (enc:v1:…) instead.
OPERATOR_DECRYPT_TOKEN=

# ── Email (Gmail SMTP). Recipients are gated by consent — mail is only sent
#    to the address on file for an account whose holder accepted the Terms &
#    Conditions (which include email/notification consent) in the app ───────
EMAIL_SENDING_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_SENDER_NAME=Eltizamati Demo
SMTP_SENDER_EMAIL=
