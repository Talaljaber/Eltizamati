.git/
.expo/
node_modules/
build/
dist/
*.lock
# This repo is pnpm-only (pnpm-lock.yaml is the committed lockfile) — a
# stray npm/yarn lockfile is always an accidental artifact of running the
# wrong package manager, never intentional.
package-lock.json
yarn.lock
.env*
!.env.example
!apps/mobile/.env.example
*.keystore
*.p8
*.p12
*.cer
*.mobileprovision
supabase/.temp/
.claude/worktrees/

# Developer-local agent/skill installations are tooling state, not product source.
.claude/
.agents/
skills-lock.json

# TypeScript build output (never hand-authored; regenerated by `tsc --build`)
*.tsbuildinfo
*.d.ts.map
apps/mobile/app/**/*.d.ts
apps/mobile/src/**/*.d.ts
packages/*/vitest.config.d.ts

# Test coverage output
coverage/
.pnpm-store/
.mcp.json
