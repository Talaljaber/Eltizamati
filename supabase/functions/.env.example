# Server-side only. Do not put these in apps/mobile/.env.
# learn-assistant calls OpenRouter (OpenAI-chat-completions-compatible).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
# Legacy fallback names — still read if the OPENROUTER_* ones above are unset.
OPENAI_API_KEY=
OPENAI_MODEL=
# user-encryption-key: base64-encoded 32-byte AES-256 master key (KEK) that wraps each user's
# per-user field-encryption DEK. Generate with: openssl rand -base64 32
# NEVER commit a real value here. Rotating this value orphans every previously wrapped DEK —
# treat it as a one-time-set production secret (supabase secrets set FIELD_ENC_KEK=...).
FIELD_ENC_KEK=
# operator-decrypt: shared token the bank-simulator dashboard presents (x-operator-token) to
# decrypt PII for display. Generate a fresh one — this is NOT the KEK: openssl rand -hex 32
# Set the SAME value in the dashboard's OPERATOR_DECRYPT_TOKEN env var.
OPERATOR_DECRYPT_TOKEN=
