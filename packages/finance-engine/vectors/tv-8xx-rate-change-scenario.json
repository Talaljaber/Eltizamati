{
  "formulaId": "rateChangeScenario",
  "formulaVersion": 1,
  "definition": "projected total still payable = scheduled payments strictly after asOf + projected residual at maturity",
  "vectors": [
    {
      "id": "TV-801",
      "description": "A higher hypothetical rate with an unchanged installment increases the projected total still payable for the canonical scenario fixture.",
      "inputs": {
        "principal": "12000.000",
        "annualRatePercent": "7.5",
        "hypotheticalAnnualRatePercent": "10",
        "installment": "300.000",
        "termMonths": 48,
        "startDate": "2025-01-01",
        "effectiveDate": "2026-01-01",
        "asOf": "2025-12-01"
      },
      "expected": {
        "installmentUnchanged": "300.000",
        "projectedTotalStillPayableRelationship": "hypotheticalGreaterThanBaseline",
        "persistedWrites": 0
      }
    },
    {
      "id": "TV-802",
      "description": "A lower hypothetical rate does not increase projected total still payable.",
      "inputs": {
        "principal": "12000.000",
        "annualRatePercent": "7.5",
        "hypotheticalAnnualRatePercent": "4",
        "installment": "300.000",
        "termMonths": 48,
        "startDate": "2025-01-01",
        "effectiveDate": "2026-01-01",
        "asOf": "2025-12-01"
      },
      "expected": {
        "installmentUnchanged": "300.000",
        "projectedTotalStillPayableRelationship": "hypotheticalNotGreaterThanBaseline",
        "persistedWrites": 0
      }
    }
  ]
}
